<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.backend.mapper.NotificationMapper">
  <resultMap id="NotificationItemResultMap" type="com.example.backend.dto.notification.NotificationItem">
    <constructor>
      <arg column="notification_id" javaType="java.lang.String" />
      <arg column="title" javaType="java.lang.String" />
      <arg column="body" javaType="java.lang.String" />
      <arg column="type" javaType="java.lang.String" />
      <arg column="is_read" javaType="_boolean" />
      <arg column="created_at" javaType="java.lang.String" />
      <arg column="target_course_id" javaType="java.lang.String" />
      <arg column="target_division" javaType="java.lang.String" />
      <arg column="target_request_id" javaType="java.lang.String" />
    </constructor>
  </resultMap>

  <resultMap id="NotificationDetailResultMap" type="com.example.backend.dto.notification.NotificationDetailResponse">
    <constructor>
      <arg column="notification_id" javaType="java.lang.String" />
      <arg column="title" javaType="java.lang.String" />
      <arg column="body" javaType="java.lang.String" />
      <arg column="type" javaType="java.lang.String" />
      <arg column="is_read" javaType="_boolean" />
      <arg column="created_at" javaType="java.lang.String" />
      <arg column="sender_name" javaType="java.lang.String" />
      <arg column="course_id" javaType="java.lang.String" />
      <arg column="course_name" javaType="java.lang.String" />
      <arg column="division" javaType="java.lang.String" />
      <arg column="target_course_id" javaType="java.lang.String" />
      <arg column="target_division" javaType="java.lang.String" />
      <arg column="target_request_id" javaType="java.lang.String" />
      <arg column="request_reason" javaType="java.lang.String" />
    </constructor>
  </resultMap>

  <select id="findNotifications" resultMap="NotificationItemResultMap">
    SELECT
      notification_id,
      title,
      body,
      type,
      is_read,
      created_at,
      target_course_id,
      target_division,
      target_request_id
    FROM V_NOTIFICATION_LIST
    WHERE recipient_s_id = #{studentId}
    ORDER BY sort_created_at DESC, sort_notification_id DESC
  </select>

  <select id="callGetNotificationDetail" statementType="CALLABLE" parameterType="map">
    { call GET_NOTIFICATION_DETAIL(
      #{studentId, mode=IN, jdbcType=VARCHAR},
      #{notificationId, mode=IN, jdbcType=VARCHAR},
      #{result, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.example.backend.mapper.NotificationMapper.NotificationDetailResultMap}
    ) }
  </select>

  <select id="callMarkNotificationAsRead" statementType="CALLABLE">
    { call MARK_NOTIFICATION_AS_READ(
      #{studentId, mode=IN, jdbcType=VARCHAR},
      #{notificationId, mode=IN, jdbcType=VARCHAR}
    ) }
  </select>
</mapper>
